{
  // Double Mach Reflection on an ADAPTIVE conforming mesh (h-AMR by newest-vertex
  // bisection). Same physics as dmr_config.json; the mesh is refined only at the
  // shocks + slip line and coarsened elsewhere, so far fewer elements reach the
  // same effective resolution as the uniform ny=150 run.
  "ord": 2,

  // --- adaptive mesh (TUNED: coarse base + deep refinement) ---
  // A COARSE base (1/25) with DEEP refinement (max_gen=5) reaches the SAME finest
  // cell (altitude h_min ~ 1/200, leg ~ 1/141) as the old base_ny=50/max_gen=3, but
  // puts cells only at the features -> ~1/3 the elements in the smooth far field.
  // Measured: global-dt full run 603.8s -> 407.3s (1.48x) at identical final-frame
  // quality (density vs the old config: 0.89/255 mean pixel diff).  Do NOT enable LTS
  // here: in the developed DMR the shock + KH vortex street make the fine-cell
  // fraction ~50%+, so the dt-class spread collapses and LTS is ~1.8x SLOWER than
  // global-dt (LTS only pays off when a SMALL region needs the fine dt).
  "base_ny": 25,          // base-mesh cells in y (h_base = 1/25)
  "max_gen": 5,           // max NVB bisections from base => finest h_min ~ 1/200 at the shocks
  "use_lts": false,       // local time stepping OFF (not suited to the turbulent DMR; see above)
  "remesh_every": 6,      // remesh cadence (steps)
  "buffer_layers": 3,     // refine-buffer width so the shock can't outrun the fine zone
  "th_ref": 0.30,         // refine where relative density variation across a cell > 0.30
  "th_crs": 0.08,         // coarsen where it falls below 0.08 (hysteresis)
  "init_passes": 12,      // initial-adaptation sweeps (refine the IC shock to max_gen)

  "domain_xb": 4.5,
  "t_end": 0.30,
  "cfl": 0.70,            // dt = cfl * h_min / ((2k+1) * 1.15*max|u+c|)  =>  effective CFL ~ cfl/1.15 = 0.61.
                          //   Swept to t=0.30: 0.6/0.7 stable; >=0.8 risks a LATE NaN (the turbulent flow can
                          //   accelerate >1.15x within a 6-step remesh window -> local CFL spike). 0.7 is the
                          //   highest value verified stable + quality-matched; use 0.6 for extra margin.
  "lambda_safe": 19.0,   // floor on max|u+c| (not binding for Mach 10; guards low-speed transients)
  "n_frames": 300,

  // shock capturing (matches dmr_config.json)
  "use_av": true,
  "av_c": 1.2,
  "av_kappa": 1.0,
  "sigma_ip": 20.0,
  "av_refresh": 5,
  "use_positivity": true,

  // output: clean density movie + mesh-overlay movie + final stills
  "full_movie": true,
  "mesh_movie": true,
  "save_state": true,

  "Wpix": 1920,
  "render_xa": 0.0, "render_xb": 4.4, "render_ya": 0.0, "render_yb": 1.0,
  "rho_lo": 1.4, "rho_hi": 21.0,
  "cmap": "inferno",

  "zoom_xa": 3.32, "zoom_xb": 4.12, "zoom_ya": 0.0, "zoom_yb": 0.42,
  "frames_dir": "dmr_amr_frames"
}
