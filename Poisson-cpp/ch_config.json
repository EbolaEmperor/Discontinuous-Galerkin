{
  // ===== Cahn-Hilliard solver configuration =====
  // Edit values and re-run:  ./build/cahn_hilliard ch_config.json   (no recompile needed)
  // // line and /* */ block comments are allowed. Any omitted key falls back to the
  // built-in default. Run from the Poisson-cpp/ directory so this file is auto-found.

  // ---- domain ----
  "domain":     "square", // "square" ([0,1]^2) | "hexagon" | "disk" (alias "circle").
  "domain_radius": 0.5,   // hexagon circumradius / disk radius; centred at (0.5,0.5). (Ignored for square.)

  // ---- spatial discretisation ----
  "ord":        1,        // polynomial degree P_k (>=1). P1 is fast; the renderer uses vertex values.
  "N":          128,      // resolution: element size h = 1/N. Bigger N = finer detail (slower).
  "eps":        0.015,    // interface-width parameter. Smaller => thinner interfaces & more, smaller domains
                          //   (needs finer N to resolve: keep h <~ 0.83*eps).
  "sigma":      "auto",   // SIPG interior penalty. "auto" = 3*ord*(ord+1); or give a number.
  "beta":       1.0,      // SIPG variant; keep 1.0 (symmetric) for energy stability.

  // ---- model ----
  "mob":        1.0,      // mobility M.
  "S":          2.0,      // stabilisation (>= L/2; S=2 is safe for |c| <= 1.29).

  // ---- time stepping ----
  // ADAPTIVE mode: tau is chosen per step from the solution change — small while the
  // field changes fast (early spinodal phase), large once it coarsens slowly. Because
  // steps are dense early, frames are dense early too, so the fast start plays SLOWLY
  // and the slow coarsening is skimmed through. (Adaptive uses 1st-order backward Euler.)
  "adaptive":   true,
  "t_end":      0.30,     // stop at this physical time.
  "tau_min":    1e-8,     // smallest step / initial step (used during the fast early phase).
  "tau_max":    2e-4,     // largest step (used during slow coarsening).
  "rel_change": 2.5e-3,   // target relative change per step → sets the pacing (smaller = slower/finer).
  "save_every": 40,       // one frame per this many steps (with adaptive tau this ≈ equal change per frame).
  "max_steps":  200000,   // safety cap.

  // For a FIXED-step run instead, set "adaptive": false and use these:
  "time_order": 1,        // 1 = stabilised backward-Euler (robust); 2 = SBDF2 (2nd order). (Adaptive: always 1.)
  "tau":        2.5e-5,   // fixed time step.
  "n_steps":    12000,    // fixed-mode number of steps; T = n_steps * tau.

  // ---- initial condition (random spinodal) ----
  "cbar":       0.0,      // mean concentration of the random field.
  "amp":        0.10,     // white-noise amplitude (larger = more random / higher-contrast start).
  "seed":       20240601, // RNG seed (reproducible run).

  // ---- rendering ----
  "Npix":       512,      // frame resolution in pixels (square, must be even).
  "normalize":  true,     // per-frame rescale to [-1,1] by max|c| so the faint early field is vivid.
  "cmin":       -1.0,     // colormap lower bound (used only when normalize=false).
  "cmax":       1.0,      // colormap upper bound (used only when normalize=false).
  "frames_dir": "ch_frames"  // output directory for the PPM frames.
}
